{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "QingJuan",
  "version": "0.2.0",
  "identifier": "com.qingjuan.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "青卷",
        "width": 1480,
        "height": 960,
        "minWidth": 1180,
        "minHeight": 780,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/qingjuan-backend"
    ]
  }
}
